{
  "name": "educational-record-system",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start:client": "ng serve",
    "start:server": "cd backend/src && ts-node-dev index.ts",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.1.0",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.8",
    "express": "^5.2.1",
    "mysql2": "^3.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/localize": "^21.1.0",
    "@ng-bootstrap/ng-bootstrap": "^20.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "jsdom": "^27.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
